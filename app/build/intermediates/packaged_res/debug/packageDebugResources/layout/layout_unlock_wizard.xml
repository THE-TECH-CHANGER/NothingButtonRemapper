<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/black"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="UNLOCK"
        android:fontFamily="@font/doto_variable"
        android:textSize="24sp"
        android:textColor="@color/white"
        android:layout_marginBottom="24dp"
        android:letterSpacing="0.1"/>

    <!-- Consumer Packages Card -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_reference_card"
        android:orientation="vertical"
        android:padding="16dp"
        android:layout_marginBottom="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CONSUMER PACKAGES"
            android:fontFamily="@font/space_mono_regular"
            android:textSize="10sp"
            android:textColor="@color/label"
            android:textAllCaps="true"
            android:layout_marginBottom="16dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">
            <TextView
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="Essential Space"
                android:fontFamily="@font/space_mono_regular"
                android:textSize="12sp"
                android:textColor="@color/white" />
            <TextView
                android:id="@+id/tvSpaceStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="UNKNOWN"
                android:fontFamily="@font/space_mono_bold"
                android:textSize="10sp"
                android:textColor="@color/label"
                android:textAllCaps="true"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <TextView
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="Essential Recorder"
                android:fontFamily="@font/space_mono_regular"
                android:textSize="12sp"
                android:textColor="@color/white" />
            <TextView
                android:id="@+id/tvRecorderStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="UNKNOWN"
                android:fontFamily="@font/space_mono_bold"
                android:textSize="10sp"
                android:textColor="@color/label"
                android:textAllCaps="true"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Shizuku Card -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_reference_card"
        android:orientation="vertical"
        android:padding="16dp"
        android:layout_marginBottom="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SHIZUKU (ON-DEVICE)"
            android:fontFamily="@font/space_mono_regular"
            android:textSize="10sp"
            android:textColor="@color/label"
            android:textAllCaps="true"
            android:layout_marginBottom="16dp" />

        <TextView
            android:id="@+id/tvShizukuStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Shizuku checking..."
            android:fontFamily="@font/space_mono_regular"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="16dp" />

        <Button
            android:id="@+id/btnFreeSinglePress"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@drawable/bg_action_btn"
            android:backgroundTint="@color/white"
            android:text="FREE SINGLE PRESS"
            android:fontFamily="@font/space_mono_bold"
            android:textSize="14sp"
            android:textColor="@color/black"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnRestore"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@drawable/bg_action_btn"
            android:text="RESTORE"
            android:fontFamily="@font/space_mono_bold"
            android:textSize="14sp"
            android:textColor="@color/text_secondary" />
    </LinearLayout>
    
</LinearLayout>
