<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/black"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="CHOOSE ACTION"
        android:fontFamily="@font/doto_variable"
        android:textSize="24sp"
        android:textColor="@color/white"
        android:layout_marginBottom="8dp"
        android:letterSpacing="0.1"/>

    <TextView
        android:id="@+id/tvActionPickerSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Single press"
        android:fontFamily="@font/space_mono_regular"
        android:textSize="14sp"
        android:textColor="@color/text_secondary"
        android:layout_marginBottom="24dp" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Constraints -->
            <TextView
                android:id="@+id/tvConstraintHeader"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CONDITION (CONSTRAINT)"
                android:fontFamily="@font/space_mono_regular"
                android:textSize="10sp"
                android:textColor="@color/label"
                android:textAllCaps="true"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:id="@+id/btnChooseConstraint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_reference_card"
                android:padding="16dp"
                android:layout_marginBottom="24dp"
                android:orientation="vertical">
                
                <TextView
                    android:id="@+id/tvCurrentConstraint"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Always (Any State)"
                    android:fontFamily="@font/space_mono_regular"
                    android:textSize="14sp"
                    android:textColor="@color/white" />
            </LinearLayout>

            <!-- Built-in Actions -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_reference_card"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_marginBottom="24dp">

                <TextView
                    android:id="@+id/tvBuiltInHeader"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="BUILT-IN ACTIONS"
                    android:fontFamily="@font/space_mono_regular"
                    android:textSize="10sp"
                    android:textColor="@color/label"
                    android:textAllCaps="true"
                    android:layout_marginBottom="16dp" />

                <LinearLayout
                    android:id="@+id/llBuiltInActions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />

            </LinearLayout>

            <!-- Simulate Keycode -->
            <LinearLayout
                android:id="@+id/llSimulateKeyContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_reference_card"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_marginBottom="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SIMULATE KEY (REQUIRES KEYBOARD)"
                    android:fontFamily="@font/space_mono_regular"
                    android:textSize="10sp"
                    android:textColor="@color/label"
                    android:textAllCaps="true"
                    android:layout_marginBottom="16dp" />

                <LinearLayout
                    android:id="@+id/btnSimulateKeycode"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:background="@drawable/bg_action_btn"
                    android:backgroundTint="@color/white"
                    android:gravity="center"
                    android:orientation="horizontal">
                    
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ENTER KEYCODE"
                        android:fontFamily="@font/space_mono_bold"
                        android:textSize="14sp"
                        android:textColor="@color/black" />
                </LinearLayout>

            </LinearLayout>
            <!-- Launch App -->
            <TextView
                android:id="@+id/tvLaunchAppHeader"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="LAUNCH APP"
                android:fontFamily="@font/space_mono_regular"
                android:textSize="10sp"
                android:textColor="@color/label"
                android:textAllCaps="true"
                android:layout_marginBottom="16dp" />

                <LinearLayout
                    android:id="@+id/llApps"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>
