<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black"
    android:padding="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:clipChildren="false">

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ESSENTIAL KEY\nTOOLS"
            android:fontFamily="@font/doto_variable"
            android:textSize="32sp"
            android:textColor="@color/white"
            android:layout_marginBottom="32dp"
            android:letterSpacing="0.1"/>

        <!-- Service Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_reference_card"
            android:orientation="vertical"
            android:padding="20dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SERVICE"
                android:fontFamily="@font/space_mono_regular"
                android:textSize="12sp"
                android:textColor="@color/label"
                android:textAllCaps="true"
                android:layout_marginBottom="16dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <View
                    android:id="@+id/indicatorService"
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="@drawable/bg_status_dot_red"
                    android:layout_marginEnd="12dp" />

                <TextView
                    android:id="@+id/tvServiceStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SERVICE - STOPPED"
                    android:fontFamily="@font/space_mono_bold"
                    android:textSize="14sp"
                    android:textColor="@color/white"
                    android:textAllCaps="true"/>
            </LinearLayout>

            <Button
                android:id="@+id/btnServiceAction"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/bg_action_btn"
                android:text="ENABLE ACCESSIBILITY"
                android:fontFamily="@font/space_mono_bold"
                android:textSize="14sp"
                android:textColor="@color/text_secondary" />
        </LinearLayout>

        <!-- Unlock Wizard Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_reference_card"
            android:orientation="vertical"
            android:padding="20dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SINGLE-PRESS UNLOCK"
                android:fontFamily="@font/space_mono_regular"
                android:textSize="12sp"
                android:textColor="@color/label"
                android:textAllCaps="true"
                android:layout_marginBottom="16dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <View
                    android:id="@+id/indicatorUnlock"
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="@drawable/bg_status_dot_red"
                    android:layout_marginEnd="12dp" />

                <TextView
                    android:id="@+id/tvUnlockStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SINGLE PRESS - LOCKED"
                    android:fontFamily="@font/space_mono_bold"
                    android:textSize="14sp"
                    android:textColor="@color/white"
                    android:textAllCaps="true"/>
            </LinearLayout>

            <Button
                android:id="@+id/btnUnlockWizard"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/bg_action_btn"
                android:text="UNLOCK WIZARD"
                android:fontFamily="@font/space_mono_bold"
                android:textSize="14sp"
                android:textColor="@color/text_secondary" />
        </LinearLayout>

        <!-- Gestures Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_reference_card"
            android:orientation="vertical"
            android:padding="20dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="24dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="PROFILES"
                    android:fontFamily="@font/space_mono_regular"
                    android:textSize="12sp"
                    android:textColor="@color/label"
                    android:textAllCaps="true" />
                
                <LinearLayout
                    android:id="@+id/btnRemoveProfile"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="@drawable/bg_action_btn"
                    android:gravity="center"
                    android:clickable="true"
                    android:focusable="true"
                    android:layout_marginEnd="8dp"
                    android:visibility="gone">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="-"
                        android:fontFamily="@font/space_mono_bold"
                        android:textSize="18sp"
                        android:textColor="@color/white" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/btnAddProfile"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="@drawable/bg_action_btn"
                    android:gravity="center"
                    android:clickable="true"
                    android:focusable="true"
                    android:layout_marginEnd="8dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="+"
                        android:fontFamily="@font/space_mono_bold"
                        android:textSize="16sp"
                        android:textColor="@color/white" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/btnProfileSelector"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_action_btn"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="6dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:orientation="horizontal">
                    <TextView
                        android:id="@+id/tvCurrentProfile"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Global"
                        android:fontFamily="@font/space_mono_bold"
                        android:textSize="12sp"
                        android:textColor="@color/white" />
                </LinearLayout>
            </LinearLayout>

            <!-- Single Press -->
            <LinearLayout
                android:id="@+id/rowSinglePress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:clickable="true"
                android:focusable="true"
                android:paddingVertical="8dp"
                android:layout_marginBottom="16dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="Single press"
                    android:fontFamily="@font/space_mono_regular"
                    android:textSize="16sp"
                    android:textColor="@color/white" />
                <TextView
                    android:id="@+id/tvSingleAction"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="None"
                    android:fontFamily="@font/space_mono_bold"
                    android:textSize="14sp"
                    android:textColor="@color/white" />
            </LinearLayout>

            <!-- Double Press -->
            <LinearLayout
                android:id="@+id/rowDoublePress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:clickable="true"
                android:focusable="true"
                android:paddingVertical="8dp"
                android:layout_marginBottom="16dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="Double press"
                    android:fontFamily="@font/space_mono_regular"
                    android:textSize="16sp"
                    android:textColor="@color/white" />
                <TextView
                    android:id="@+id/tvDoubleAction"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="None"
                    android:fontFamily="@font/space_mono_bold"
                    android:textSize="14sp"
                    android:textColor="@color/white" />
            </LinearLayout>

            <!-- Triple Press -->
            <LinearLayout
                android:id="@+id/rowTriplePress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:clickable="true"
                android:focusable="true"
                android:paddingVertical="8dp"
                android:layout_marginBottom="16dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="Triple press"
                    android:fontFamily="@font/space_mono_regular"
                    android:textSize="16sp"
                    android:textColor="@color/white" />
                <TextView
                    android:id="@+id/tvTripleAction"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="None"
                    android:fontFamily="@font/space_mono_bold"
                    android:textSize="14sp"
                    android:textColor="@color/white" />
            </LinearLayout>

            <!-- Long Press -->
            <LinearLayout
                android:id="@+id/rowLongPress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:clickable="true"
                android:focusable="true"
                android:paddingVertical="8dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="Long press"
                    android:fontFamily="@font/space_mono_regular"
                    android:textSize="16sp"
                    android:textColor="@color/white" />
                <TextView
                    android:id="@+id/tvLongAction"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="None"
                    android:fontFamily="@font/space_mono_bold"
                    android:textSize="14sp"
                    android:textColor="@color/white" />
            </LinearLayout>
        </LinearLayout>

        <!-- Expert Mode / Key Test Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_reference_card"
            android:orientation="vertical"
            android:padding="20dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="KEY EVENTS (EXPERT MODE)"
                android:fontFamily="@font/space_mono_regular"
                android:textSize="12sp"
                android:textColor="@color/label"
                android:textAllCaps="true"
                android:layout_marginBottom="16dp" />

            <TextView
                android:id="@+id/tvKeyEvents"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Waiting for key press..."
                android:fontFamily="@font/space_mono_regular"
                android:textSize="14sp"
                android:textColor="@color/white" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
